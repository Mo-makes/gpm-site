# Resend API key for contact form email delivery
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=

# The email address that receives contact form submissions
CONTACT_EMAIL=info@globalpainmd.com

# Optional: Google Maps Embed API key
# If left blank, the embed will use the public Maps embed URL (no key required for basic embeds)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
